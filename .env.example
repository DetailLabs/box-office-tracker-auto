# Recommended: Any random string to protect the manual refresh endpoint
REFRESH_SECRET=any_random_string_here

# Optional: Server port (Replit sets this automatically)
PORT=3001

# Optional: When set to "true", a successful refresh commits data/*.json and
# runs `git push`, which triggers a Vercel redeploy with the new weekend.
# Requires the Replit git remote to have push credentials (e.g. a PAT in the URL).
PUSH_ON_REFRESH=false
